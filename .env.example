# --- Cloud Supabase (recommended for this app) ---
# Dashboard → Project Settings → API → copy Project URL and anon public key
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-jwt-key

# --- AI (Gemini) — server only, never VITE_* ---
# Supabase Dashboard → Project Settings → Edge Functions → Secrets:
#   GEMINI_API_KEY=...
#   GEMINI_MODEL=gemini-2.5-flash   (optional)

# --- Local Supabase (optional) — use when `npx supabase start` is running ---
# Comment cloud lines above, then:
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<from `npx supabase status`>
